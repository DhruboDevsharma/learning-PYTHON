{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "run python",
      "type": "shell",
      "command": "python",
      "args": [
        "${file}"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": []
    },
    {
      "label": "run python with input/output",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "python \"${file}\" < input.txt > output.txt"
      ],
      "dependsOn": "run python",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
